generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  citizen
  volunteer
  ngo
  admin
}

enum ReportStatus {
  open
  in_progress
  resolved
  rejected
}

enum CampaignStatus {
  active
  paused
  completed
}

enum ServiceType {
  vet
  hospital
  pharmacy
}

model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  name        String
  role        UserRole @default(citizen)

  avatarUrl   String?
  fcmToken    String?

  wardId      String?
  city        String?
  state       String?

  lat         Float?
  lng         Float?

  xpTotal     Int      @default(0)
  streak      Int      @default(0)

  reports      Report[]
  donations    Donation[]
  xpLedger     XPLedger[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id          String       @id @default(uuid())
  userId      String

  module      String
  photoUrl    String
  description String

  lat         Float
  lng         Float

  status      ReportStatus @default(open)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Campaign {
  id            String @id @default(uuid())

  title         String
  story         String

  goalAmount    Float
  raisedAmount  Float @default(0)

  beneficiaryId String

  status CampaignStatus @default(active)

  donations Donation[]

  createdAt DateTime @default(now())
}

model Donation {
  id                String @id @default(uuid())

  donorId           String
  campaignId        String

  amount            Float

  razorpayOrderId   String?
  razorpayPaymentId String?

  receiptUrl        String?

  createdAt DateTime @default(now())

  donor User @relation(fields: [donorId], references: [id])

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

model XPLedger {
  id        String @id @default(uuid())

  userId    String

  eventType String

  xpAwarded Int

  capped Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Badge {
  id String @id @default(uuid())

  name String

  iconUrl String

  xpBonus Int

  condition Json
}

model Service {
  id String @id @default(uuid())

  name String

  type ServiceType

  lat Float
  lng Float

  phone String

  city String

  verified Boolean @default(false)
}